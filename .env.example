# ── Server ──────────────────────────────────────────────────────────
PORT=4000
# Public origin of THIS backend (used to build update download URLs).
PUBLIC_URL=http://localhost:4000
# Comma-separated origins allowed to call the checkout/license endpoints
# (your marketing site). e.g. https://jorapress.com,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ── Database (MongoDB) ──────────────────────────────────────────────
# Local mongod or a MongoDB Atlas connection string.
MONGODB_URI=mongodb://127.0.0.1:27017/jorapress

# ── Stripe (payment collection only) ────────────────────────────────
# No Stripe Products/Prices needed — plans + pricing live in src/config.ts
# and are charged via an inline price at checkout.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Where Stripe sends the customer after paying / cancelling.
CHECKOUT_SUCCESS_URL=http://localhost:3000/checkout/success
CHECKOUT_CANCEL_URL=http://localhost:3000/checkout

# ── Email (license delivery) ────────────────────────────────────────
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@jorapress.com
SMTP_PASS=
MAIL_FROM="JoraPress <info@jorapress.com>"

# ── Plugin distribution / updates ───────────────────────────────────
# The latest plugin version you have published, and the zip to serve.
PLUGIN_VERSION=0.1.0
PLUGIN_ZIP_PATH=./releases/jorapress.zip
